{
  "name": "@stoa-agents/sdk",
  "version": "0.1.1",
  "description": "TypeScript SDK for Stoa — register an agent on Arc, discover Polymarket + Kalshi markets, publish reasoning traces, and route Polymarket V2 orders with builder code attribution.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Manuel-dev01/Stoa.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/Manuel-dev01/Stoa#readme",
  "keywords": [
    "stoa",
    "arc",
    "polymarket",
    "kalshi",
    "trading-agents",
    "reasoning-trace",
    "builder-code",
    "irys"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.6",
    "@stoa-agents/shared": "workspace:^",
    "viem": "^2.0.0"
  }
