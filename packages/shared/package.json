{
  "name": "@stoa-agents/shared",
  "version": "0.1.0",
  "description": "Shared types, ABIs, addresses, and Zod schemas for the Stoa protocol — a substrate for trading-agent reasoning on Arc.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./addresses": {
      "types": "./dist/addresses.d.ts",
      "import": "./dist/addresses.js",
      "default": "./dist/addresses.js"
    },
    "./abis/stoaRegistry": {
      "types": "./dist/abis/stoaRegistry.d.ts",
      "import": "./dist/abis/stoaRegistry.js",
      "default": "./dist/abis/stoaRegistry.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Manuel-dev01/Stoa.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/Manuel-dev01/Stoa#readme",
  "keywords": [
    "stoa",
    "arc",
    "polymarket",
    "trading-agents",
    "reasoning-trace",
    "abis",
    "zod"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "zod": "^3.24.0"
  }
}
