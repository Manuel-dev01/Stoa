# Stoa Agent — Environment Variables
# Copy to .env.local and fill in your values.

# --- Networks ---
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
STOA_REGISTRY_ADDRESS=0x19Ea8a442802065a61c69cbc03bE97724Ad8cd9b

# --- Agent identity ---
# Set after running: uv run python -m stoa_agent.cli register
AGENT_ID=
# Only needed when USE_CIRCLE_WALLETS=false (raw key mode)
AGENT_PRIVATE_KEY=

# --- Circle Wallets (Programmable Wallets) ---
# Set USE_CIRCLE_WALLETS=true to use Circle-managed wallets instead of raw keys.
# Get credentials from https://console.circle.com
USE_CIRCLE_WALLETS=false
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
# Set after running: uv run python -m stoa_agent.cli circle-setup
CIRCLE_WALLET_ID=
CIRCLE_WALLET_SET_ID=

# --- LLM ---
DEEPSEEK_API_KEY=

# --- Irys ---
IRYS_PRIVATE_KEY=
IRYS_NODE_URL=https://devnet.irys.xyz
IRYS_TOKEN=matic
IRYS_PROVIDER_URL=https://rpc-amoy.polygon.technology

# --- Supabase (state persistence across restarts) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Persona classification (multi-agent daemon) ---
# After each publish the daemon POSTs the trace hash to the web app so the
# classifier can run. Defaults to the production URL if unset.
STOA_APP_URL=https://stoa-agents.vercel.app
# Optional shared secret; must match INDEXER_AUTH_TOKEN set on the web app.
INDEXER_AUTH_TOKEN=
