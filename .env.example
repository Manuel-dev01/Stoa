# Networks
ARC_TESTNET_RPC=
ARC_TESTNET_CHAIN_ID=
POLYGON_RPC=
POLYGON_CHAIN_ID=137

# Deployer key — only used by Foundry deploy scripts, never imported in app code
DEPLOYER_PRIVATE_KEY=

# Agent wallet key — used by the Python agent service for on-chain trace publication
AGENT_PRIVATE_KEY=

# Circle
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
CIRCLE_ENTITY_SECRET=
CIRCLE_APP_KIT_PROJECT_ID=
# Set after running: cd apps/agent && uv run python -m stoa_agent.cli circle-setup
CIRCLE_WALLET_ID=
# Set to true to use Circle Wallets instead of raw private keys for agent on-chain txs
USE_CIRCLE_WALLETS=false

# Polymarket
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_BUILDER_CODE=
# Relayer API Key for deposit wallet deployment (get from polymarket.com/settings)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# Irys
IRYS_PRIVATE_KEY=
IRYS_NODE_URL=https://devnet.irys.xyz
IRYS_TOKEN=matic
IRYS_PROVIDER_URL=https://rpc-amoy.polygon.technology

# Supabase
# The web API routes accept SUPABASE_URL or NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional shared secret gating /api/v1/internal/classify-trace.
# Set the same value here and in the daemon's environment to lock it down.
INDEXER_AUTH_TOKEN=

# LLM provider — DeepSeek powers The Calibrator (and is the fallback for all agents)
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Extra LLM providers routed onto the Triad (env names start with a digit on
# purpose; config.py maps them via validation_alias).
#   2_LLM_* → The Quantec   (e.g. Groq llama-3.3-70b-versatile)
#   3_LLM_* → The Bayesian  (e.g. Gemini gemini-2.5-flash) + embeddings
2_LLM_MODEL=
2_LLM_API_KEY=
2_LLM_BASE_URL=
3_LLM_MODEL=
3_LLM_API_KEY=
3_LLM_BASE_URL=

# Macro data for The Quantec (free key: https://fred.stlouisfed.org)
FRED_API_KEY=

# x402 tollbooth (the feed gate). ARC_USDC_ADDRESS restricts the ERC-20 path to
# real USDC; STOA_TREASURY_ADDRESS is the toll recipient.
ARC_RPC_URL=
STOA_TREASURY_ADDRESS=
ARC_USDC_ADDRESS=
X402_TOLL_USDC=0.005
X402_USDC_DECIMALS=6

# Indexer
INDEXER_START_BLOCK=
INDEXER_POLL_INTERVAL_MS=5000

# Frontend public vars (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_ARC_RPC=
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_USDC=
NEXT_PUBLIC_STOA_REGISTRY_ADDRESS=
NEXT_PUBLIC_STOA_TREASURY_ADDRESS=

# Circle App Kit (free kit key from https://console.circle.com)
NEXT_PUBLIC_CIRCLE_KIT_KEY=

# Dynamic (wallet auth — get from https://app.dynamic.xyz)
NEXT_PUBLIC_DYNAMIC_ENV_ID=

# ERC-4337 bundler for Arc testnet (Circle Paymaster gas-free transactions)
NEXT_PUBLIC_BUNDLER_RPC=
